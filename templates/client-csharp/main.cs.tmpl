using System;
using System.Threading.Tasks;
using Zoit.Network;
using Zoit.Logger;

/// <summary>
/// 게임 클라이언트 - C# (Unity) 구현
/// 숫자 맞추기 게임을 자동으로 진행
/// </summary>
public class GameClient
{
    // 게임 상태 관리
    private uint playerId = 0;
    private uint roomId = 0;
    private uint opponentId = 0;
    private string opponentNickname = "";
    private uint targetNumber = 0;
    private uint maxNumber = 0;
    private bool gameStarted = false;
    private bool gameFinished = false;
    private int guessCount = 0;
    private uint low = 1;
    private uint high = 100;
    private string nickname = "CSPlayer";
    private bool isMultiplayer = true;

    public static async Task Main(string[] args)
    {
        ClientLogger.Info("🎮 C# 게임 클라이언트 시작");

        // 별도 닉네임 지정 가능
        string nickname = args.Length > 0 ? args[0] : "CSPlayer";
        // --single 플래그로 싱글플레이 모드 선택 가능
        bool isMultiplayer = !System.Linq.Enumerable.Contains(args, "--single");

        // 게임 클라이언트 생성
        var gameClient = new GameClient { nickname = nickname, isMultiplayer = isMultiplayer };

        // TCP 클라이언트 초기화
        var client = new TcpClient();

        // 프로토콜과 핸들러 바인딩
        Protocol.Register(client, gameClient.OnRecvPacket);

        // 서버 연결
        ClientLogger.Info("[Network] 서버 연결 중... (127.0.0.1:8080)");
        if (!await client.ConnectAsync("127.0.0.1", 8080))
        {
            ClientLogger.Error("[Network] 서버 연결 실패");
            return;
        }

        ClientLogger.Info("[Network] ✓ 서버 연결 성공");

        // 로그인 요청
        await gameClient.Login(client);

        // 게임 진행 (최대 60초)
        var startTime = DateTime.Now;
        while (!gameClient.gameFinished)
        {
            await Task.Delay(100);

            // 타임아웃 체크
            if ((DateTime.Now - startTime).TotalSeconds > 60)
            {
                ClientLogger.Warning("[Game] 타임아웃 - 게임 종료");
                break;
            }
        }

        ClientLogger.Info("[Game] 게임 종료");
        await client.Close();
    }

    /// <summary>
    /// 로그인 요청 전송
    /// </summary>
    private async Task Login(TcpClient client)
    {
        ClientLogger.Info($"[Game] 로그인 시도: {nickname}");
        var req = new Msg_AuthLoginReq { Nickname = nickname };
        await client.SendMessageAsync(req);
    }

    /// <summary>
    /// 방 검색 요청
    /// </summary>
    private async Task SearchRoom(TcpClient client)
    {
        ClientLogger.Info("[Game] 방 검색 중...");
        var req = new Msg_RoomSearchReq();
        await client.SendMessageAsync(req);
    }

    /// <summary>
    /// 새 방 생성 요청
    /// </summary>
    private async Task CreateRoom(TcpClient client)
    {
        string roomName = $"{nickname}의 게임방";
        string mode = isMultiplayer ? "멀티플레이" : "싱글플레이";
        ClientLogger.Info($"[Game] 방 생성: {roomName} ({mode})");
        var req = new Msg_RoomCreateReq
        {
            RoomName = roomName,
            IsMultiplayer = (uint)(isMultiplayer ? 1 : 0)
        };
        await client.SendMessageAsync(req);
    }

    /// <summary>
    /// 기존 방 입장 요청
    /// </summary>
    private async Task JoinRoom(TcpClient client, uint roomId)
    {
        ClientLogger.Info($"[Game] 방 입장: {roomId}");
        var req = new Msg_RoomJoinReq { RoomID = roomId };
        await client.SendMessageAsync(req);
    }

    /// <summary>
    /// 숫자 맞추기 요청 (이진 탐색 사용)
    /// </summary>
    private async Task GuessNumber(TcpClient client, uint guess)
    {
        guessCount++;
        ClientLogger.Info($"[Game] 숫자 맞추기: {guess} (시도 {guessCount}번)");
        var req = new Msg_GuessReq { GuessNumber = guess };
        await client.SendMessageAsync(req);
    }

    /// <summary>
    /// 게임 승리 메시지 전송
    /// </summary>
    private async Task SendWin(TcpClient client)
    {
        ClientLogger.Info("[Game] 게임 승리!");
        var req = new Msg_WinReq { GuessNumber = targetNumber };
        await client.SendMessageAsync(req);
    }

    /// <summary>
    /// 채팅 메시지 전송
    /// </summary>
    private async Task SendChat(TcpClient client, string message)
    {
        ClientLogger.Info($"[Chat] {nickname}: {message}");
        var req = new Msg_ChatReq { Message = message };
        await client.SendMessageAsync(req);
    }

    /// <summary>
    /// 패킷 수신 핸들러 - 모든 메시지의 진입점
    /// </summary>
    private async void OnRecvPacket(object client, object msg)
    {
        var tcpClient = (TcpClient)client;

        if (msg is Msg_AuthLoginRes loginRes)
        {
            await HandleLoginResponse(tcpClient, loginRes);
        }
        else if (msg is Msg_RoomSearchRes searchRes)
        {
            await HandleRoomSearchResponse(tcpClient, searchRes);
        }
        else if (msg is Msg_RoomCreateRes createRes)
        {
            await HandleRoomCreateResponse(tcpClient, createRes);
        }
        else if (msg is Msg_RoomJoinRes joinRes)
        {
            await HandleRoomJoinResponse(tcpClient, joinRes);
        }
        else if (msg is Msg_GameStartNotify startNotify)
        {
            await HandleGameStartNotify(startNotify);
        }
        else if (msg is Msg_GuessRes guessRes)
        {
            await HandleGuessResponse(tcpClient, guessRes);
        }
        else if (msg is Msg_GuessNotify guessNotify)
        {
            await HandleGuessNotify(guessNotify);
        }
        else if (msg is Msg_WinRes winRes)
        {
            await HandleWinResponse(winRes);
        }
        else if (msg is Msg_WinNotify winNotify)
        {
            await HandleWinNotify(winNotify);
        }
        else if (msg is Msg_ChatRes chatRes)
        {
            await HandleChatResponse(chatRes);
        }
        else if (msg is Msg_ChatNotify chatNotify)
        {
            await HandleChatNotify(chatNotify);
        }
        else if (msg is Msg_SystemTCPHeartBitRes)
        {
            // 하트비트 응답 (로깅 생략)
        }
    }

    /// <summary>
    /// 로그인 응답 처리
    /// </summary>
    private async Task HandleLoginResponse(TcpClient client, Msg_AuthLoginRes msg)
    {
        if (msg.Result == 0)
        {
            playerId = msg.PlayerID;
            ClientLogger.Info($"[Game] ✓ 로그인 성공 (ID: {msg.PlayerID})");

            await Task.Delay(500);
            await SearchRoom(client);
        }
        else
        {
            ClientLogger.Error($"[Game] ✗ 로그인 실패: {msg.Result}");
        }
    }

    /// <summary>
    /// 방 검색 응답 처리
    /// </summary>
    private async Task HandleRoomSearchResponse(TcpClient client, Msg_RoomSearchRes msg)
    {
        if (msg.Result == 0)
        {
            if (msg.Rooms != null && msg.Rooms.Length > 0)
            {
                var room = msg.Rooms[0];
                ClientLogger.Info($"[Game] ✓ 방 발견: {room.RoomName} (ID: {room.RoomID}, 플레이어 수: {room.PlayerCount})");
                await Task.Delay(500);
                await JoinRoom(client, room.RoomID);
            }
            else
            {
                ClientLogger.Info("[Game] 대기 중인 방이 없음, 새 방 생성");
                await Task.Delay(500);
                await CreateRoom(client);
            }
        }
    }

    /// <summary>
    /// 방 생성 응답 처리
    /// </summary>
    private async Task HandleRoomCreateResponse(TcpClient client, Msg_RoomCreateRes msg)
    {
        if (msg.Result == 0)
        {
            roomId = msg.RoomID;
            ClientLogger.Info($"[Game] ✓ 방 생성 완료 (ID: {msg.RoomID})");
            ClientLogger.Info("[Game] ⏳ 다른 플레이어 대기 중...");
        }
    }

    /// <summary>
    /// 방 입장 응답 처리
    /// </summary>
    private async Task HandleRoomJoinResponse(TcpClient client, Msg_RoomJoinRes msg)
    {
        if (msg.Result == 0)
        {
            roomId = msg.RoomID;
            opponentId = msg.OpponentPlayerID;
            opponentNickname = msg.OpponentNickname;
            ClientLogger.Info($"[Game] ✓ 방 입장 완료");
            ClientLogger.Info($"[Game] ⚔️  상대 플레이어: {msg.OpponentNickname}");
            ClientLogger.Info("[Game] ⏳ 게임 시작 대기 중...");
        }
    }

    /// <summary>
    /// 게임 시작 알림 처리
    /// </summary>
    private async Task HandleGameStartNotify(Msg_GameStartNotify msg)
    {
        targetNumber = msg.TargetNumber;
        maxNumber = msg.MaxNumber;
        gameStarted = true;
        ClientLogger.Info($"[Game] 🎮 게임 시작! (숫자 범위: 1~{msg.MaxNumber})");

        // 첫 번째 추측
        low = 1;
        high = msg.MaxNumber;
    }

    /// <summary>
    /// 숫자 맞추기 응답 처리 (이진 탐색)
    /// </summary>
    private async Task HandleGuessResponse(TcpClient client, Msg_GuessRes msg)
    {
        if (msg.Hint == 0) // 너무 작음
        {
            ClientLogger.Info($"[Game] 📈 너무 작습니다. 범위 조정: {low} ~ {high}");
            low = (uint)(guessCount + 1);

            await Task.Delay(500);
            uint nextGuess = (low + high) / 2;
            await GuessNumber(client, nextGuess);
        }
        else if (msg.Hint == 1) // 너무 큼
        {
            ClientLogger.Info($"[Game] 📉 너무 큽니다. 범위 조정: {low} ~ {high}");
            high = (uint)(guessCount - 1);

            await Task.Delay(500);
            uint nextGuess = (low + high) / 2;
            await GuessNumber(client, nextGuess);
        }
        else if (msg.Hint == 2) // 정답
        {
            ClientLogger.Info("[Game] 🎉 정답입니다!");
            await Task.Delay(500);
            await SendWin(client);
        }
    }

    /// <summary>
    /// 상대 플레이어의 추측 알림
    /// </summary>
    private async Task HandleGuessNotify(Msg_GuessNotify msg)
    {
        string[] hints = { "📈 작음", "📉 큼", "🎉 정답" };
        string hintText = msg.Hint < 3 ? hints[msg.Hint] : "?";
        ClientLogger.Info($"[Game] 상대 플레이어 추측: {msg.Nickname} → {msg.GuessNumber} ({hintText})");
    }

    /// <summary>
    /// 게임 승리 응답 처리
    /// </summary>
    private async Task HandleWinResponse(Msg_WinRes msg)
    {
        if (msg.Result == 0)
        {
            ClientLogger.Info("[Game] ✓ 승리 메시지 전송 완료");
        }
    }

    /// <summary>
    /// 게임 종료 알림 처리
    /// </summary>
    private async Task HandleWinNotify(Msg_WinNotify msg)
    {
        gameFinished = true;

        if (msg.WinnerPlayerID == playerId)
        {
            ClientLogger.Info($"[Game] 🏆 승리! (시도 {msg.TryCount}회)");
        }
        else
        {
            ClientLogger.Info($"[Game] 💔 패배 - {msg.WinnerNickname}가 {msg.TryCount}회만에 맞췄습니다!");
        }

        ClientLogger.Info($"[Game] 정답: {msg.CorrectNumber}");
    }

    /// <summary>
    /// 채팅 응답 처리
    /// </summary>
    private async Task HandleChatResponse(Msg_ChatRes msg)
    {
        if (msg.Result == 0)
        {
            ClientLogger.Debug("[Chat] ✓ 메시지 전송 완료");
        }
    }

    /// <summary>
    /// 채팅 메시지 수신
    /// </summary>
    private async Task HandleChatNotify(Msg_ChatNotify msg)
    {
        ClientLogger.Info($"[Chat] {msg.Nickname}: {msg.Message}");
    }
}
