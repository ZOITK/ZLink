import asyncio
import random
from zoit_socket_client.network.tcp_client import AsyncTcpClient
from zoit_socket_client.logger.logger import logger
import protocol.Protocol as protocol


# 게임 클라이언트 상태 관리
class GameClient:
    def __init__(self, nickname: str, is_multiplayer: bool = True):
        self.nickname = nickname
        self.is_multiplayer = is_multiplayer
        self.player_id = None
        self.room_id = None
        self.opponent_id = None
        self.opponent_nickname = None
        self.target_number = None
        self.max_number = None
        self.game_started = False
        self.game_finished = False
        self.low = 1
        self.high = 100
        self.guess_count = 0

    async def login(self, client):
        """로그인 요청 전송"""
        logger.info(f"[Game] 로그인 시도: {self.nickname}")
        req = protocol.Msg_AuthLoginReq(Nickname=self.nickname)
        await client.Send(req.BuildTCP())

    async def search_room(self, client):
        """방 검색 요청"""
        logger.info("[Game] 방 검색 중...")
        req = protocol.Msg_RoomSearchReq()
        await client.Send(req.BuildTCP())

    async def create_room(self, client):
        """새 방 생성"""
        room_name = f"{self.nickname}의 게임방"
        mode = "멀티플레이" if self.is_multiplayer else "싱글플레이"
        logger.info(f"[Game] 방 생성: {room_name} ({mode})")
        req = protocol.Msg_RoomCreateReq(RoomName=room_name, IsMultiplayer=1 if self.is_multiplayer else 0)
        await client.Send(req.BuildTCP())

    async def join_room(self, client, room_id):
        """기존 방 입장"""
        logger.info(f"[Game] 방 입장: {room_id}")
        req = protocol.Msg_RoomJoinReq(RoomID=room_id)
        await client.Send(req.BuildTCP())

    async def guess_number(self, client, guess: int):
        """숫자 맞추기 (이진 탐색)"""
        self.guess_count += 1
        logger.info(f"[Game] 숫자 맞추기: {guess} (시도 {self.guess_count}번)")
        req = protocol.Msg_GuessReq(GuessNumber=guess)
        await client.Send(req.BuildTCP())

    async def send_win(self, client):
        """게임 승리 메시지"""
        logger.info("[Game] 게임 승리!")
        req = protocol.Msg_WinReq(GuessNumber=self.target_number)
        await client.Send(req.BuildTCP())

    async def send_chat(self, client, message: str):
        """채팅 메시지 전송"""
        logger.info(f"[Chat] {self.nickname}: {message}")
        req = protocol.Msg_ChatReq(Message=message)
        await client.Send(req.BuildTCP())


# 게임 클라이언트 전역 인스턴스
game_client = None


async def OnRecvPacket(client, msg):
    """패킷 수신 핸들러 - 모든 메시지의 진입점"""
    global game_client

    if isinstance(msg, protocol.Msg_AuthLoginRes):
        await handle_login_response(client, msg)

    elif isinstance(msg, protocol.Msg_RoomSearchRes):
        await handle_room_search_response(client, msg)

    elif isinstance(msg, protocol.Msg_RoomCreateRes):
        await handle_room_create_response(client, msg)

    elif isinstance(msg, protocol.Msg_RoomJoinRes):
        await handle_room_join_response(client, msg)

    elif isinstance(msg, protocol.Msg_GameStartNotify):
        await handle_game_start_notify(msg)

    elif isinstance(msg, protocol.Msg_GuessRes):
        await handle_guess_response(client, msg)

    elif isinstance(msg, protocol.Msg_GuessNotify):
        await handle_guess_notify(msg)

    elif isinstance(msg, protocol.Msg_WinRes):
        await handle_win_response(msg)

    elif isinstance(msg, protocol.Msg_WinNotify):
        await handle_win_notify(msg)

    elif isinstance(msg, protocol.Msg_ChatRes):
        await handle_chat_response(msg)

    elif isinstance(msg, protocol.Msg_ChatNotify):
        await handle_chat_notify(msg)

    elif isinstance(msg, protocol.Msg_SystemTCPHeartBitRes):
        logger.debug(f"[System] 하트비트 응답: {msg.ServerTime}")


async def handle_login_response(client, msg):
    """로그인 응답 처리"""
    global game_client
    if msg.Result == 0:
        game_client.player_id = msg.PlayerID
        logger.info(f"[Game] ✓ 로그인 성공 (ID: {msg.PlayerID})")

        # 방 검색
        await asyncio.sleep(0.5)
        await game_client.search_room(client)
    else:
        logger.error(f"[Game] ✗ 로그인 실패: {msg.Result}")


async def handle_room_search_response(client, msg):
    """방 검색 응답 처리"""
    global game_client
    if msg.Result == 0:
        if len(msg.Rooms) > 0:
            # 첫 번째 방에 입장
            room = msg.Rooms[0]
            logger.info(f"[Game] ✓ 방 발견: {room.RoomName} (ID: {room.RoomID}, 플레이어 수: {room.PlayerCount})")
            await asyncio.sleep(0.5)
            await game_client.join_room(client, room.RoomID)
        else:
            # 새 방 생성
            logger.info("[Game] 대기 중인 방이 없음, 새 방 생성")
            await asyncio.sleep(0.5)
            await game_client.create_room(client)


async def handle_room_create_response(client, msg):
    """방 생성 응답 처리"""
    global game_client
    if msg.Result == 0:
        game_client.room_id = msg.RoomID
        logger.info(f"[Game] ✓ 방 생성 완료 (ID: {msg.RoomID})")
        logger.info("[Game] ⏳ 다른 플레이어 대기 중...")


async def handle_room_join_response(client, msg):
    """방 입장 응답 처리"""
    global game_client
    if msg.Result == 0:
        game_client.room_id = msg.RoomID
        game_client.opponent_id = msg.OpponentPlayerID
        game_client.opponent_nickname = msg.OpponentNickname
        logger.info(f"[Game] ✓ 방 입장 완료")
        logger.info(f"[Game] ⚔️  상대 플레이어: {msg.OpponentNickname}")
        logger.info("[Game] ⏳ 게임 시작 대기 중...")


async def handle_game_start_notify(msg):
    """게임 시작 알림 처리"""
    global game_client
    game_client.target_number = msg.TargetNumber
    game_client.max_number = msg.MaxNumber
    game_client.game_started = True
    logger.info(f"[Game] 🎮 게임 시작! (숫자 범위: 1~{msg.MaxNumber})")

    # 첫 번째 추측 (이진 탐색)
    game_client.low = 1
    game_client.high = msg.MaxNumber


async def handle_guess_response(client, msg):
    """숫자 맞추기 응답 처리 (0: 작음, 1: 큼, 2: 정답)"""
    global game_client

    if msg.Hint == 0:  # 너무 작음
        logger.info(f"[Game] 📈 너무 작습니다. 범위 조정: {game_client.low} ~ {game_client.high}")
        game_client.low = game_client.guess_count + 1

        # 다음 추측
        await asyncio.sleep(0.5)
        next_guess = (game_client.low + game_client.high) // 2
        await game_client.guess_number(client, next_guess)

    elif msg.Hint == 1:  # 너무 큼
        logger.info(f"[Game] 📉 너무 큽니다. 범위 조정: {game_client.low} ~ {game_client.high}")
        game_client.high = game_client.guess_count - 1

        # 다음 추측
        await asyncio.sleep(0.5)
        next_guess = (game_client.low + game_client.high) // 2
        await game_client.guess_number(client, next_guess)

    elif msg.Hint == 2:  # 정답
        logger.info("[Game] 🎉 정답입니다!")
        await asyncio.sleep(0.5)
        await game_client.send_win(client)


async def handle_guess_notify(msg):
    """상대 플레이어의 추측 알림"""
    hint_text = ["📈 작음", "📉 큼", "🎉 정답"][msg.Hint] if msg.Hint < 3 else "?"
    logger.info(f"[Game] 상대 플레이어 추측: {msg.Nickname} → {msg.GuessNumber} ({hint_text})")


async def handle_win_response(msg):
    """게임 승리 응답"""
    if msg.Result == 0:
        logger.info("[Game] ✓ 승리 메시지 전송 완료")


async def handle_win_notify(msg):
    """게임 종료 알림"""
    global game_client
    game_client.game_finished = True

    if msg.WinnerPlayerID == game_client.player_id:
        logger.info(f"[Game] 🏆 승리! (시도 {msg.TryCount}회)")
    else:
        logger.info(f"[Game] 💔 패배 - {msg.WinnerNickname}가 {msg.TryCount}회만에 맞췄습니다!")

    logger.info(f"[Game] 정답: {msg.CorrectNumber}")

    # 게임 종료
    await asyncio.sleep(2)


async def handle_chat_response(msg):
    """채팅 응답"""
    if msg.Result == 0:
        logger.debug("[Chat] ✓ 메시지 전송 완료")


async def handle_chat_notify(msg):
    """채팅 메시지 수신"""
    logger.info(f"[Chat] {msg.Nickname}: {msg.Message}")


async def main():
    """메인 함수 - 게임 실행"""
    global game_client

    logger.info("🎮 Python 게임 클라이언트 시작")

    # 클라이언트 초기화
    client = AsyncTcpClient(Host="127.0.0.1", Port=8080)
    protocol.Register(client, OnRecvPacket)

    # 게임 클라이언트 생성
    import sys
    nickname = sys.argv[1] if len(sys.argv) > 1 else "Player1"
    # --single 플래그로 싱글플레이 모드 선택 가능
    is_multiplayer = "--single" not in sys.argv
    game_client = GameClient(nickname, is_multiplayer=is_multiplayer)

    # 서버 연결
    logger.info(f"[Network] 서버 연결 중... (127.0.0.1:8080)")
    if not await client.Connect():
        logger.error("[Network] 서버 연결 실패")
        return

    logger.info("[Network] ✓ 서버 연결 성공")

    # 로그인
    await game_client.login(client)

    # 게임 진행
    start_time = asyncio.get_event_loop().time()
    timeout = 60  # 60초 타임아웃

    while not game_client.game_finished:
        await asyncio.sleep(0.1)

        # 타임아웃 체크
        if asyncio.get_event_loop().time() - start_time > timeout:
            logger.warning("[Game] 타임아웃 - 게임 종료")
            break

    logger.info("[Game] 게임 종료")
    await client.Close()


if __name__ == "__main__":
    try:
        asyncio.run(main())
    except KeyboardInterrupt:
        logger.info("사용자에 의해 중단됨")
    except Exception as e:
        logger.error(f"오류 발생: {e}")
